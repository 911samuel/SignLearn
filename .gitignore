# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
.eggs/
pip-log.txt
.env
.venv/
venv/
ENV/

# ── ML artifacts ─────────────────────────────────────────────────────────────
models/
*.h5
*.pkl
*.pt
*.pth
*.keras

# ── Data (keep READMEs) ───────────────────────────────────────────────────────
data/raw/
data/processed/
data/external/

# ── Runtime artifacts (generated, not tracked) ────────────────────────────────
# `artifacts/*` (not `artifacts/`) so git walks the dir and the negations below
# can re-include individual production-served files.  A parent directory ignore
# rule can't be undone — only its contents can.
artifacts/*
!artifacts/.gitkeep
!artifacts/label_map.json
!artifacts/checkpoints/
artifacts/checkpoints/*
!artifacts/checkpoints/tcn_best.onnx
!artifacts/checkpoints/tcn_best.classes.json

# ── Test / CI caches ─────────────────────────────────────────────────────────
.pytest_cache/
coverage/
*.log

# ── Node / Next.js ───────────────────────────────────────────────────────────
node_modules/
frontend/.next/
frontend/next-env.d.ts
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment secrets ───────────────────────────────────────────────────────
.env.local
.env.*.local
frontend/.env.local
frontend/.env.*.local

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.sqlite3

# ── Claude Code local config ─────────────────────────────────────────────────
.claude/
frontend/.claude/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
